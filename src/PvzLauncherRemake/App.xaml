<Application x:Class="PvzLauncherRemake.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PvzLauncherRemake"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->

            <LinearGradientBrush x:Key="BorderBrush"/>
            <SolidColorBrush x:Key="BackgroundBrush"/>

            <LinearGradientBrush x:Key="VirtualImportTextBrush" StartPoint="0,0.5" EndPoint="1,0.5">
                <GradientStop Color="#FF3FD8" Offset="0.0" />
                <GradientStop Color="#993FFF" Offset="1.0" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </Application.Resources>
</Application>
