<Window x:Class="PvzLauncherRemake.Windows.WindowOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PvzLauncherRemake.Windows"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:icons="clr-namespace:PvzLauncherRemake.Controls.Icons"
        mc:Ignorable="d"
        Title="WindowOverlay" Height="600" Width="800" WindowStyle="None" Topmost="True" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False"
        Closing="Window_Closing" Loaded="Window_Loaded"
        
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:ResxLocalizationProvider.DefaultAssembly="PvzLauncherRemake"
        lex:ResxLocalizationProvider.DefaultDictionary="I18N.WindowOverlay">
    <Grid Margin="3,26,3,3">
        <Rectangle Fill="#7F000000"/>
        <!--上栏-->
        <!--时间-->
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,20,0,0">
            <TextBlock x:Name="textBlock_Time" Foreground="White" Text="12:00:00" FontSize="25" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBlock x:Name="textBlock_Date" Foreground="White" Text="1970.1.1 星期一"/>
        </StackPanel>
        <!--标题-->
        <icons:TitleImageEn Width="350" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,20,0,0"/>
        <!--右上按钮-->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,20,20,0">
            <Button x:Name="button_KillGame" Height="35" Margin="0,0,10,0" Background="{x:Null}" Foreground="#E4FF1919" Click="button_KillGame_Click">
                <Button.BorderBrush>
                    <LinearGradientBrush EndPoint="0,3" MappingMode="Absolute">
                        <LinearGradientBrush.RelativeTransform>
                            <ScaleTransform CenterY="0.5" ScaleY="-1"/>
                        </LinearGradientBrush.RelativeTransform>
                        <GradientStop Color="#A3FF0000" Offset="0.33"/>
                        <GradientStop Color="#3DFF0000" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
                <StackPanel Orientation="Horizontal">
                    <ui:PathIcon Height="15" Width="15" Data="M324-111.5Q251-143 197-197t-85.5-127Q80-397 80-480t31.5-156Q143-709 197-763t127-85.5Q397-880 480-880t156 31.5Q709-817 763-763t85.5 127Q880-563 880-480t-31.5 156Q817-251 763-197t-127 85.5Q563-80 480-80t-156-31.5ZM707-253q93-93 93-227t-93-227q-93-93-227-93t-227 93q-93 93-93 227t93 227q93 93 227 93t227-93Zm-57-57q70-70 70-170 0-51-19-94.5T650-650l-57 57q22 22 34.5 51t12.5 62q0 66-47 113t-113 47q-66 0-113-47t-47-113q0-33 12.5-62t34.5-51l-57-57q-32 32-51 75.5T240-480q0 100 70 170t170 70q100 0 170-70ZM440-480h80v-240h-80v240Zm40 0Z" Margin="0,0,5,0"/>
                    <TextBlock Text="{lex:Loc KillGame}"/>
                </StackPanel>
            </Button>

            <Button x:Name="button_HideOverlay" Width="35" Height="35" Background="{x:Null}" Click="button_HideOverlay_Click">
                <ui:PathIcon Height="10" Width="10" Data="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z"/>
            </Button>
        </StackPanel>
        
        
        <TabControl Style="{StaticResource TabControlPivotStyle}" Margin="0,100,0,0">
            <!--主页-->
            <TabItem Header="{lex:Loc Home}">
                <StackPanel>
                    <TextBlock Text="{lex:Loc Welcome1}" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold" FontSize="20"/>
                    <TextBlock Text="{lex:Loc Welcome2}" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold" FontSize="20"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        
    </Grid>
</Window>
